case(NETWORK_TYPE)
	`FORWARD_NETWORK:
		case(ROUTER_ID)
			`ROUTER_ID_I_ROUTER00:
				case(target_node)
					`NODE_ID_I_SNIM_I_SYSTEM_SRAM_NO_NAME: routing_info = 8'b 00000001;
					`NODE_ID_I_SNIM_COMMON_PERI_GROUP_NO_NAME: routing_info = 8'b 00000001;
					`NODE_ID_I_SNIM_EXTERNAL_PERI_GROUP_NO_NAME: routing_info = 8'b 00000001;
					`NODE_ID_I_SNIM_PLATFORM_CONTROLLER_NO_NAME: routing_info = 8'b 00000001;
					`NODE_ID_DEFAULT_SLAVE: routing_info = 8'b 00000001;
					`NODE_ID_I_SNIM_I_DCA_MATRIX_CONV00_CONTROL_MMIOX1_INTERFACE_MMIO: routing_info = 8'b 00000001;
					`NODE_ID_I_SNIM_I_DCA_MATRIX_MAC00_CONTROL_MMIOX1_INTERFACE_MMIO: routing_info = 8'b 00000001;
					`NODE_ID_I_SNIM_I_SYSTEM_DDR_NO_NAME: routing_info = 8'b 00000010;
				endcase
			`ROUTER_ID_I_SYSTEM_ROUTER:
				case(target_node)
					`NODE_ID_I_SNIM_I_SYSTEM_SRAM_NO_NAME: routing_info = 7'b 0000001;
					`NODE_ID_I_SNIM_COMMON_PERI_GROUP_NO_NAME: routing_info = 7'b 0000010;
					`NODE_ID_I_SNIM_EXTERNAL_PERI_GROUP_NO_NAME: routing_info = 7'b 0000100;
					`NODE_ID_I_SNIM_PLATFORM_CONTROLLER_NO_NAME: routing_info = 7'b 0001000;
					`NODE_ID_DEFAULT_SLAVE: routing_info = 7'b 0010000;
					`NODE_ID_I_SNIM_I_DCA_MATRIX_CONV00_CONTROL_MMIOX1_INTERFACE_MMIO: routing_info = 7'b 0100000;
					`NODE_ID_I_SNIM_I_DCA_MATRIX_MAC00_CONTROL_MMIOX1_INTERFACE_MMIO: routing_info = 7'b 1000000;
				endcase
			`ROUTER_ID_I_USER_ROUTER:
				case(target_node)
					`NODE_ID_I_SNIM_I_SYSTEM_DDR_NO_NAME: routing_info = 8'b 00000001;
					`NODE_ID_I_SNIM_I_SYSTEM_SRAM_NO_NAME: routing_info = 8'b 00000010;
					`NODE_ID_I_SNIM_COMMON_PERI_GROUP_NO_NAME: routing_info = 8'b 00000010;
					`NODE_ID_I_SNIM_EXTERNAL_PERI_GROUP_NO_NAME: routing_info = 8'b 00000010;
					`NODE_ID_I_SNIM_PLATFORM_CONTROLLER_NO_NAME: routing_info = 8'b 00000010;
					`NODE_ID_DEFAULT_SLAVE: routing_info = 8'b 00000010;
					`NODE_ID_I_SNIM_I_DCA_MATRIX_CONV00_CONTROL_MMIOX1_INTERFACE_MMIO: routing_info = 8'b 00000010;
					`NODE_ID_I_SNIM_I_DCA_MATRIX_MAC00_CONTROL_MMIOX1_INTERFACE_MMIO: routing_info = 8'b 00000010;
				endcase
		endcase
	`BACKWARD_NETWORK:
		case(ROUTER_ID)
			`ROUTER_ID_I_ROUTER00:
				case(target_node)
					`NODE_ID_I_MNIM_I_MAIN_CORE_NO_NAME: routing_info = 4'b 0001;
					`NODE_ID_I_MNIM_I_SUB_CORE_001_NO_NAME: routing_info = 4'b 0010;
					`NODE_ID_I_MNIM_I_SUB_CORE_002_NO_NAME: routing_info = 4'b 0100;
					`NODE_ID_I_MNIM_I_SUB_CORE_003_NO_NAME: routing_info = 4'b 1000;
				endcase
			`ROUTER_ID_I_SYSTEM_ROUTER:
				case(target_node)
					`NODE_ID_I_MNIM_I_MAIN_CORE_NO_NAME: routing_info = 11'b 00000000001;
					`NODE_ID_I_MNIM_I_SUB_CORE_001_NO_NAME: routing_info = 11'b 00000000001;
					`NODE_ID_I_MNIM_I_SUB_CORE_002_NO_NAME: routing_info = 11'b 00000000001;
					`NODE_ID_I_MNIM_I_SUB_CORE_003_NO_NAME: routing_info = 11'b 00000000001;
					`NODE_ID_I_MNIM_PLATFORM_CONTROLLER_MASTER: routing_info = 11'b 00000000010;
					`NODE_ID_I_MNIM_I_DCA_MATRIX_CONV00_MI_MLSU_NOC_PART: routing_info = 11'b 00000000010;
					`NODE_ID_I_MNIM_I_DCA_MATRIX_CONV00_MK_MLSU_NOC_PART: routing_info = 11'b 00000000010;
					`NODE_ID_I_MNIM_I_DCA_MATRIX_CONV00_MO_MLSU_NOC_PART: routing_info = 11'b 00000000010;
					`NODE_ID_I_MNIM_I_DCA_MATRIX_MAC00_MA_MLSU_NOC_PART: routing_info = 11'b 00000000010;
					`NODE_ID_I_MNIM_I_DCA_MATRIX_MAC00_MB_MLSU_NOC_PART: routing_info = 11'b 00000000010;
					`NODE_ID_I_MNIM_I_DCA_MATRIX_MAC00_MC_MLSU_NOC_PART: routing_info = 11'b 00000000010;
				endcase
			`ROUTER_ID_I_USER_ROUTER:
				case(target_node)
					`NODE_ID_I_MNIM_I_MAIN_CORE_NO_NAME: routing_info = 11'b 00000000001;
					`NODE_ID_I_MNIM_I_SUB_CORE_001_NO_NAME: routing_info = 11'b 00000000001;
					`NODE_ID_I_MNIM_I_SUB_CORE_002_NO_NAME: routing_info = 11'b 00000000001;
					`NODE_ID_I_MNIM_I_SUB_CORE_003_NO_NAME: routing_info = 11'b 00000000001;
					`NODE_ID_I_MNIM_PLATFORM_CONTROLLER_MASTER: routing_info = 11'b 00000000010;
					`NODE_ID_I_MNIM_I_DCA_MATRIX_CONV00_MI_MLSU_NOC_PART: routing_info = 11'b 00000000100;
					`NODE_ID_I_MNIM_I_DCA_MATRIX_CONV00_MK_MLSU_NOC_PART: routing_info = 11'b 00000001000;
					`NODE_ID_I_MNIM_I_DCA_MATRIX_CONV00_MO_MLSU_NOC_PART: routing_info = 11'b 00000010000;
					`NODE_ID_I_MNIM_I_DCA_MATRIX_MAC00_MA_MLSU_NOC_PART: routing_info = 11'b 00000100000;
					`NODE_ID_I_MNIM_I_DCA_MATRIX_MAC00_MB_MLSU_NOC_PART: routing_info = 11'b 00001000000;
					`NODE_ID_I_MNIM_I_DCA_MATRIX_MAC00_MC_MLSU_NOC_PART: routing_info = 11'b 00010000000;
				endcase
		endcase
endcase